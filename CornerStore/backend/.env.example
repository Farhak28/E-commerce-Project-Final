ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5141

ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=ECommerceDBOnline;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;Encrypt=False
ConnectionStrings__IdentityConnection=Server=localhost,1433;Database=ECommerceDBOnline.Security;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;Encrypt=False
ConnectionStrings__RedisConnection=localhost:6379

JWTOptions__Issuer=CornerStore
JWTOptions__Audience=CornerStoreUsers
JWTOptions__SecretKey=CHANGE_ME_USE_A_LONG_RANDOM_SECRET

# Optional: create the first admin when the identity DB has no users (first run only)
# BootstrapAdmin__Email=
# BootstrapAdmin__Password=
# BootstrapAdmin__DisplayName=Corner Store Admin
# BootstrapAdmin__Role=SuperAdmin

# Gemini AI shopping assistant (required for /api/Assistant/chat)
GEMINI_API_KEY=

# Stripe (test keys — publishable key is safe in the browser; secret stays server-side)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Or use ASP.NET config names:
# Stripe__SKey=
# Stripe__PublishableKey=

# Optional AI tuning (maps to appsettings AI section)
# AI__ModelName=gemini-2.5-flash
# AI__EmbeddingModelName=text-embedding-004
# AI__ModelName=gemini-2.5-flash
# AI__Temperature=0.4
# AI__MaxTokens=2048
# AI__ChunkSize=800
# AI__ChunkOverlap=100
# AI__TopKRetrieval=5
# AI__HistoryLength=20
# AI__MaxRetries=3
