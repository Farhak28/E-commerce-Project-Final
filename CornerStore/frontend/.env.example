# Next.js public API base URL (browser + server fallback)
NEXT_PUBLIC_API_URL=http://localhost:5141/api

# API host for uploaded product images (required for admin/catalog previews)
NEXT_PUBLIC_API_ORIGIN=http://localhost:5141

# Used by the frontend container to reach the API inside Docker Compose
API_INTERNAL_URL=http://localhost:5141/api

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
# Required for card / Apple Pay. InstaPay and cash on delivery work without Stripe.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Gemini AI assistant — set GEMINI_API_KEY on the backend only (docker-compose / appsettings)
# GEMINI_API_KEY=