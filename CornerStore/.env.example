# Docker Compose overrides (copy to .env at repository root — Docker loads .env, not .env.example)

FRONTEND_PORT=3848
API_PORT=5141

# SQL Server SA password (must match docker-compose.yml — local dev default only)
MSSQL_SA_PASSWORD=YourStrong@Passw0rd

# JWT signing secret (backend Docker) — generate a long random string for production
JWT_OPTIONS__SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_SECRET

# Stripe publishable key (must match secret key pair in backend Stripe__SKey)
# Required at frontend *build* time for Docker: docker compose up --build
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=Stripe__PKey

# Backend Stripe secret (also set Stripe__SKey in docker-compose)
STRIPE_SECRET_KEY=Stripe__SKey

# Gemini AI assistant — backend only (from https://aistudio.google.com/api-keys)
GEMINI_API_KEY=
# Use a current model (gemini-1.5-flash was removed from the API)
AI__ModelName=gemini-2.5-flash
